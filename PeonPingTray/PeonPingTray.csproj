<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <RootNamespace>PeonPingTray</RootNamespace>
    <AssemblyName>PeonPingTray</AssemblyName>
    <ApplicationIcon>Resources\peon.ico</ApplicationIcon>
    <Version>1.0.0</Version>
    <Company>hpsmcgregor</Company>
    <Copyright>MIT (c) hpsmcgregor</Copyright>
    <SelfContained>false</SelfContained>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\peon.png" LogicalName="PeonPingTray.Resources.peon.png" />
  </ItemGroup>

</Project>
